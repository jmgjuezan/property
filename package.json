{
  "name": "property",
  "description": "property management user interface",
  "author": {
    "name": "John Juezan",
    "email": "jmgjuezan@yahoo.com"
  },
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-tenant": "env-cmd -f .env.local-tenant next dev",
    "dev:test": "env-cmd -f .env.test next dev",
    "dev:test-tenant": "env-cmd -f .env.test-tenant next dev",
    "dev:sandbox": "env-cmd -f .env.sandbox next dev",
    "dev:sandbox-tenant": "env-cmd -f .env.sandbox-tenant next dev",
    "build": "next build",
    "build-tenant": "env-cmd -f .env.local-tenant next build",
    "build:test": "env-cmd -f .env.test next build",
    "build:test-tenant": "env-cmd -f .env.test-tenant next build",
    "build:sandbox": "env-cmd -f .env.sandbox next build",
    "build:sandbox-tenant": "env-cmd -f .env.sandbox-tenant next build",
    "start": "next build && next start",
    "start:tenant": "npm run build-tenant && env-cmd -f .env.local-tenant next start",
    "start:test": "npm run build:test && env-cmd -f .env.test next start",
    "start:test-tenant": "npm run build:test-tenant && env-cmd -f .env.test-tenant next start",
    "start:sandbox": "npm run build:sandbox && env-cmd -f .env.sandbox next start",
    "start:sandbox-tenant": "npm run build:sandbox-tenant && env-cmd -f .env.sandbox-tenant next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "dayjs": "^1.11.21",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4"
  }
}
